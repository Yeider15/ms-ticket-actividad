    enviar(destino) {
        console.log(`[SIMULACIÓN STRATEGY] Enviando WhatsApp al contacto ${destino}...`);
    }
}

// Estrategia 2: SMS
class SMSStrategy extends INotificacionStrategy {
    enviar(destino) {
        console.log(`[SIMULACIÓN STRATEGY] Enviando SMS al número ${destino}...`);
    }
}

